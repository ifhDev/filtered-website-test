---
import PortfolioLayout from "../../layouts/PortfolioLayout.astro";
import { getCollection } from "astro:content";
import { getPrefix, navHref } from "../../utils/nav";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const prefix = getPrefix(Astro.url);
---

<PortfolioLayout
  title="Blog"
  description="Thoughts on all kinds of things — from Martina Mustermann."
>
  <section class="max-w-3xl section-wrap py-12 sm:py-16">
    <h1 class="heading-hero text-3xl">Blog</h1>
    <p class="text-base body-text mt-2">Thoughts on all kinds of things.</p>

    {
      posts.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <h3 class="text-base font-semibold text-text-primary">
            No posts yet
          </h3>
          <p class="text-sm text-text-secondary mt-1 max-w-xs">
            Blog posts are coming soon. Check back for updates on releases,
            behind-the-scenes, and more.
          </p>
        </div>
      ) : (
        <ul class="mt-8 divide-y divide-border">
          {posts.map((post) => (
            <li class="py-6">
              <a
                href={navHref(prefix, `/blog/${post.id}`)}
                class="block group ring-focus rounded-lg -m-2 p-2"
              >
                <time
                  class="text-xs text-text-tertiary"
                  datetime={post.data.date.toISOString()}
                >
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                <h2 class="heading-section text-xl mt-1 group-hover:text-accent-text transition-safe">
                  {post.data.title}
                </h2>
                {post.data.excerpt && (
                  <p class="text-sm body-text mt-2">{post.data.excerpt}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</PortfolioLayout>
