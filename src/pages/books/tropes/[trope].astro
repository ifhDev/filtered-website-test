---
import PortfolioLayout from "../../../layouts/PortfolioLayout.astro";
import BookCard from "../../../components/BookCard.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import type { Book, Trope } from "../types";
import booksData from "../../../data/books.json";
import tropesData from "../../../data/tropes.json";
import { getPrefix, navHref } from "../../../utils/nav";

export function getStaticPaths() {
  const tropes: Trope[] = tropesData as Trope[];
  return tropes
    .filter((t) => t.canonical)
    .map((trope) => ({
      params: { trope: trope.slug },
      props: { trope: trope.slug, display: trope.name },
    }));
}

const { trope, display } = Astro.props;

const books: Book[] = booksData as Book[];
const matchingBooks = books.filter(
  (book) =>
    book.tropes.some(
      (t) =>
        t.toLowerCase().replace(/\s+/g, "-").replace(/[/]/g, "-") === trope,
    ) ||
    book.dynamics.some((d) => d.toLowerCase().replace(/\s+/g, "-") === trope),
);

const description = `Browse all Martina Mustermann books featuring the ${display} trope.`;

const prefix = getPrefix(Astro.url);
---

<PortfolioLayout title={`${display} — Trope`} description={description}>
  <section class="max-w-6xl section-wrap py-12">
    <Breadcrumb
      items={[
        { label: "Home", href: navHref(prefix, "/") },
        { label: "Books", href: navHref(prefix, "/books") },
        { label: display },
      ]}
    />

    <h1 class="heading-hero text-4xl sm:text-5xl">
      {display}
    </h1>
    <p class="text-base body-text mt-2">
      All books featuring the <span class="text-accent-text font-medium"
        >{display}</span
      > trope. Every story guarantees a Happily Ever After.
    </p>

    {
      matchingBooks.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <h3 class="text-base font-semibold text-text-primary">
            No books found
          </h3>
          <p class="text-sm text-text-secondary mt-1 max-w-xs">
            No books match this trope yet. Check back soon — new releases drop
            regularly.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
          {matchingBooks.map((book) => (
            <BookCard {...book} compact={true} />
          ))}
        </div>
      )
    }

    <div class="mt-12 pt-8 divider">
      <a href={navHref(prefix, "/books")} class="link-accent"> &larr; Back to Full Library </a>
    </div>
  </section>
</PortfolioLayout>
