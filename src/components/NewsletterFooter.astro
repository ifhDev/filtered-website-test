---
import { getPrefix, navHref } from "../utils/nav";

const prefix = getPrefix(Astro.url);
---

<footer class="divider bg-surface">
  <div class="max-w-6xl section-wrap py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="heading-section text-lg mb-4">Stay in the Loop</h3>
        <p class="text-sm body-text">
          Get release alerts, exclusive excerpts, and behind-the-scenes updates.
          No spam, ever.
        </p>
      </div>

      <div>
        <h3 class="heading-section text-lg mb-4">Connect</h3>
        <ul class="flex flex-col gap-2">
          <li>
            <a
              href="https://instagram.com/"
              class="inline-flex items-center gap-2 link-quiet"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
                ></path></svg
              >
              Instagram
            </a>
          </li>
          <li>
            <a
              href="https://twitter.com/"
              class="inline-flex items-center gap-2 link-quiet"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path></svg
              >
              X / Twitter
            </a>
          </li>
          <li>
            <a
              href="https://www.tiktok.com/"
              class="inline-flex items-center gap-2 link-quiet"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.84-.35-4.13-1.01V13.6c0 2.24.01 4.48-.01 6.72-.07 1.44-.52 2.89-1.43 4.02-1.4 1.73-3.66 2.72-5.9 2.66-2.08-.03-4.1-.89-5.52-2.42-1.44-1.49-2.14-3.58-2.05-5.63.08-1.83.81-3.63 2.05-4.97 1.38-1.52 3.4-2.43 5.44-2.52.06 1.46-.03 2.93.04 4.39-.91.14-1.86.47-2.49 1.17-.84.86-1.05 2.2-.6 3.29.4 1.03 1.37 1.8 2.46 1.99 1.15.22 2.43-.08 3.25-1.01.63-.67.88-1.6.88-2.5V.15c1.33-.02 2.66-.05 3.99-.13z"
                ></path></svg
              >
              TikTok
            </a>
          </li>
          <li>
            <a
              href="https://www.goodreads.com/"
              class="inline-flex items-center gap-2 link-quiet"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M11.43 2.16c-1.7.22-3.1.87-4.2 1.95-1.1 1.07-1.7 2.37-1.82 3.88h4.12V18H14V2h-2.57zM0 22h24v2H0z"
                ></path></svg
              >
              Goodreads
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="heading-section text-lg mb-4">Legal</h3>
        <ul class="flex flex-col gap-2">
          <li>
            <a href={navHref(prefix, "/impressum")} class="link-quiet">Impressum</a>
          </li>
          <li>
            <a href={navHref(prefix, "/privacy")} class="link-quiet">Privacy Policy</a>
          </li>
        </ul>
      </div>
    </div>

    <div id="mailerlite-form-widget"></div>

    <div class="mt-8 pt-6 divider text-center">
      <p class="text-xs text-text-tertiary">
        &copy; 2026 Martina Mustermann. All rights reserved.
      </p>
    </div>
  </div>
</footer>
