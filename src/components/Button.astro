---
interface Props {
  variant?: 'primary' | 'secondary' | 'disabled';
  size?: 'xs' | 'sm' | 'md' | 'lg';
  href?: string;
  target?: string;
  rel?: string;
  type?: string;
  class?: string;
}

const {
  variant = 'primary',
  size = 'sm',
  href,
  target,
  rel,
  type = 'button',
  class: className = '',
} = Astro.props;

const classes = `btn btn-${variant} btn-${size} ${className}`.trim();
---

{href ? (
  <a href={href} target={target} rel={rel} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} disabled={variant === 'disabled'} class={classes}>
    <slot />
  </button>
)}
