---
import type { Book } from "../types";
import tropesData from "../data/tropes.json";
import Button from "./Button.astro";
import Badge from "./Badge.astro";
import { getPrefix, navHref } from "../utils/nav";

// We extend your central Book type so we inherit all its fields automatically,
// and just add the one prop specific to this component's layout (compact).
interface Props extends Book {
  compact?: boolean;
}

const {
  id,
  title,
  series,
  positionInSeries,
  coverImage,
  altText,
  blurb,
  tropes,
  dynamics,
  purchaseOptions,
  compact = false,
  miniBlurb,
  tagLine,
} = Astro.props;

const pad = compact ? "p-3" : "p-5";
const titleSize = compact ? "text-lg md:text-xl" : "text-xl md:text-2xl";

const tropesMap = new Map<string, { canonical: boolean }>();
for (const trope of tropesData) {
  tropesMap.set(trope.name, { canonical: trope.canonical });
}

function getTropeSlug(name: string): string {
  return name.toLowerCase().replace(/\s+/g, "-").replace(/[/]/g, "-");
}

const sortedTropes = [...tropes]
  .sort((a, b) => {
    const aCanonical = tropesMap.get(a)?.canonical ?? false;
    const bCanonical = tropesMap.get(b)?.canonical ?? false;
    if (aCanonical && !bCanonical) return -1;
    if (!aCanonical && bCanonical) return 1;
    return 0;
  })
  .slice(0, 4);

// Since miniBlurb and tagLine are required in types.ts but might be empty strings ("")
// in your JSON, standard JS truthiness (||) still works perfectly here.
const displayBlurb = miniBlurb || tagLine || blurb;
const useLineClamp = !miniBlurb && !tagLine;

const prefix = getPrefix(Astro.url);
---

<article
  class={`group glass-card ${pad} motion-reduce:transition-none transition-all duration-300 hover:-translate-y-2 hover:shadow-lg hover:shadow-surface-alt/50 flex flex-col h-full`}
>
  <div
    class="w-full mx-auto aspect-[5/8] overflow-hidden rounded-lg bg-surface"
  >
    <img
      src={coverImage}
      alt={`Book cover for ${title}: ${altText}`}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>

  <div class="flex-1 flex flex-col mt-4">
    <span class="block text-xs italic text-text-tertiary mb-1">{series}</span>
    <h3 class={`heading-section ${titleSize} leading-tight`}>
      {title}
    </h3>

    <p class={`text-sm body-text mt-2 ${useLineClamp ? "line-clamp-2" : ""}`}>
      {displayBlurb}
    </p>

    <div class="inline-flex flex-wrap gap-1.5 mt-3 mb-2">
      {
        sortedTropes.map((t) => {
          const tropeInfo = tropesMap.get(t);
          const isCanonical = tropeInfo?.canonical ?? false;
          const slug = getTropeSlug(t);
          return isCanonical ? (
            <Badge kind="trope-accent" href={navHref(prefix, `/books/tropes/${slug}`)}>
              {t}
            </Badge>
          ) : (
            <Badge kind="trope">{t}</Badge>
          );
        })
      }
    </div>
  </div>

  <div class="mt-auto pt-4 divider flex flex-col sm:flex-row gap-3">
    {
      purchaseOptions && purchaseOptions.length > 0 && (
        <Button
          variant="primary"
          size="sm"
          href={purchaseOptions[0].url}
          target="_blank"
          class="flex-1"
        >
          Buy {purchaseOptions[0].format}
        </Button>
      )
    }
    <Button variant="secondary" size="sm" href={navHref(prefix, `/books/${id}`)} class="flex-1">
      Read More
    </Button>
  </div>
</article>
